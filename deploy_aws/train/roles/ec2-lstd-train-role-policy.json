{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "GetBucketLocation",
            "Effect": "Allow",
            "Action": [
                "s3:GetBucketLocation"
            ],
            "Resource": "arn:aws:s3:::my-lstd-data"
        },
        {
            "Sid": "ListOnlyTrainingPrefix",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": "arn:aws:s3:::my-lstd-data",
            "Condition": {
                "StringLike": {
                    "s3:prefix": [
                        "training-artifacts",
                        "training-artifacts/*"
                    ]
                }
            }
        },
        {
            "Sid": "ReadWriteTrainingObjectsOnly",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:AbortMultipartUpload"
            ],
            "Resource": "arn:aws:s3:::my-lstd-data/training-artifacts/*"
        }
    ]
}