{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WriteLambdaLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    },
    {
      "Sid": "GetBucketLocation",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::my-lstd-data"
    },
    {
      "Sid": "ListRelevantPrefixes",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::my-lstd-data",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "training-artifacts",
            "training-artifacts/*",
            "promoted-artifacts",
            "promoted-artifacts/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadTrainingArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::my-lstd-data/training-artifacts/*"
    },
    {
      "Sid": "WritePromotedArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::my-lstd-data/promoted-artifacts/*"
    }
  ]
}