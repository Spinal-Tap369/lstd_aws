AWS_REGION=eu-central-1 LOG_LEVEL=INFO

RAW_QUEUE_URL=https://sqs.eu-central-1.amazonaws.com/189599797847/raw-candles.fifo STREAM_STATE_TABLE=stream_state

LIVE_SYMBOL=BTCUSDT LIVE_INTERVAL=1m

ARTIFACT_BUNDLE_PATH=/opt/lstd_inference/artifacts/latest/artifact_bundle.pt RESUME_STATE_PATH=

DEVICE=cpu OUTPUTS_DIR=/opt/lstd_inference/outputs RUN_NAME=lstd_live_worker

LIVE_MODE=full N_INNER=1 ADAPT_LEARNING_RATE=1e-3 ADAPT_WEIGHT_DECAY=0.0 ADAPT_GRAD_CLIP_NORM=1.0

COMPUTE_UNSCALED_METRICS=true SAVE_ARRAYS=false SAVE_STATE_SNAPSHOT=true STATE_SNAPSHOT_NAME=worker_latest_state.pt

POLL_WAIT_SECONDS=20 BACKLOG_DRAIN_WAIT_SECONDS=1 VISIBILITY_TIMEOUT_SECONDS=900

BINANCE_REST_BASE=https://api.binance.com GAP_FILL_TIMEOUT=20 GAP_FILL_MAX_RETRIES=5 GAP_FILL_REQUEST_LIMIT=1000 GAP_FILL_SLEEP_SECONDS=0.15

TELEMETRY_ENABLED=true TELEMETRY_BUCKET=my-lstd-data TELEMETRY_PREFIX=live-telemetry TELEMETRY_LOCAL_DIR=/opt/lstd_inference/telemetry